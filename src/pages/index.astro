---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import StatsBar from '../components/StatsBar.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { company, productCategories, seoMeta } from '../data/siteData';

const meta = seoMeta.home;

const categoryImages: Record<string, string> = {
  'plastic-parts': '/images/products/fan-blade.jpg',
  'table-fans': '/images/products/table-fan-16.jpg',
  'custom-oem': '/images/products/custom-part.jpg',
};

const whyChooseUsIcons: Record<string, string> = {
  experience: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />',
  quality: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.746 3.746 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />',
  capacity: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />',
  custom: '<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.58-3.22a.9.9 0 010-1.56l5.58-3.22a.9.9 0 01.9 0l5.58 3.22a.9.9 0 010 1.56l-5.58 3.22a.9.9 0 01-.9 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M5.84 11.95l-5.58 3.22a.9.9 0 000 1.56l5.58 3.22a.9.9 0 00.9 0l5.58-3.22a.9.9 0 000-1.56l-5.58-3.22a.9.9 0 00-.9 0z" />',
};
---

<BaseLayout title={meta.title} description={meta.description}>
  <!-- Hero -->
  <HeroSection
    title={company.tagline}
    subtitle={company.description}
    backgroundImage="/images/hero-home.jpg"
    ctaText="Request a Quote"
    ctaLink="/contact"
  />

  <!-- Stats -->
  <StatsBar stats={company.stats} />

  <!-- Product Categories -->
  <section class="py-16 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Our Product Range"
        subtitle="From precision components to complete assemblies — we manufacture everything under one roof."
      />
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {productCategories.map((cat) => (
          <CategoryCard
            title={cat.title}
            description={cat.description}
            image={categoryImages[cat.id] || '/images/products/fan-blade.jpg'}
            href="/products"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Why Choose Suraj Industries"
        subtitle="Trusted by India's leading brands for over 25 years."
      />
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {company.whyChooseUs.map((reason) => (
          <div class="rounded-lg bg-white p-6 text-center shadow-md">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary/10 text-primary">
              <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <Fragment set:html={whyChooseUsIcons[reason.icon] || whyChooseUsIcons['experience']} />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-bold text-gray-900">{reason.title}</h3>
            <p class="mt-2 text-sm text-gray-600">{reason.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-primary py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Ready to Partner?</h2>
      <p class="mt-4 text-lg text-primary-200">
        Whether you need precision components, complete assemblies, or custom OEM solutions — let's discuss how we can support your manufacturing needs.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-block rounded-md bg-secondary px-8 py-3 text-base font-semibold text-gray-900 shadow-lg transition-colors hover:bg-secondary-300"
      >
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
