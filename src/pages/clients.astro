---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ClientLogo from '../components/ClientLogo.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { seoMeta, clients, testimonials } from '../data/siteData';

const meta = seoMeta.clients;
---

<BaseLayout title={meta.title} description={meta.description}>
  <HeroSection
    title="Our Clients"
    subtitle="Trusted by India's leading fan manufacturers and consumer brands for over two decades."
    backgroundImage="/images/hero-clients.jpg"
  />

  <!-- Client Logo Grid -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Brands That Trust Us"
        subtitle="We are proud to partner with some of India's most recognized names in the fan and appliance industry."
      />
      <div class="grid grid-cols-3 gap-4 sm:grid-cols-4 md:grid-cols-5 sm:gap-6">
        {clients.map((client) => (
          <ClientLogo name={client.name} logo={client.logo} />
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-gray-50 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="What Our Clients Say"
        subtitle="Long-standing partnerships built on trust, quality, and reliability."
      />
      <div class="grid gap-8 md:grid-cols-3">
        {testimonials.map((testimonial) => (
          <TestimonialCard
            quote={testimonial.quote}
            author={testimonial.author}
            designation={testimonial.designation}
            company={testimonial.company}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Partnership CTA -->
  <section class="bg-primary py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Become a Partner</h2>
      <p class="mt-4 text-lg text-primary-100">
        Looking for a reliable manufacturing partner? Let's discuss how Suraj Industries can support your business with quality components and on-time delivery.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-block rounded-md bg-secondary px-8 py-3 text-base font-semibold text-gray-900 shadow-lg transition-colors hover:bg-secondary-300"
      >
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
