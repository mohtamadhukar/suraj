---
interface Props {
  name: string;
  logo: string;
}

const { name, logo } = Astro.props;
---

<div class="flex items-center justify-center rounded-lg border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
  <img src={logo} alt={name} class="h-16 w-auto max-w-[140px] object-contain grayscale transition-all hover:grayscale-0" loading="lazy" />
</div>
