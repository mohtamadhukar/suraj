---
interface Props {
  stats: Array<{ label: string; value: string }>;
  dark?: boolean;
}

const { stats, dark = true } = Astro.props;
---

<section class:list={['py-12', dark ? 'bg-primary text-white' : 'bg-gray-50 text-gray-900']}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-3xl font-extrabold sm:text-4xl">{stat.value}</div>
          <div class:list={['mt-1 text-sm font-medium', dark ? 'text-blue-200' : 'text-gray-500']}>
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
