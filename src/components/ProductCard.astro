---
interface Props {
  id: string;
  name: string;
  specs: string;
  image: string;
}

const { id, name, specs, image } = Astro.props;
---

<div class="group flex flex-col overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm transition-shadow hover:shadow-md">
  <div class="flex h-48 items-center justify-center bg-gray-100 p-4">
    <img src={image} alt={name} class="h-full max-h-36 w-auto object-contain" loading="lazy" />
  </div>
  <div class="flex flex-1 flex-col p-5">
    <h3 class="text-lg font-semibold text-gray-900">{name}</h3>
    <p class="mt-1 flex-1 text-sm text-gray-600">{specs}</p>
    <a
      href={`/contact?product=${id}`}
      class="mt-4 inline-block rounded-md bg-primary px-4 py-2 text-center text-sm font-semibold text-white transition-colors hover:bg-primary-700"
    >
      Enquire Now
    </a>
  </div>
</div>
