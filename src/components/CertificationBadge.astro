---

<div class="flex flex-col items-center rounded-lg border border-gray-200 bg-white p-6 text-center shadow-sm">
  <div class="flex h-16 w-16 items-center justify-center rounded-full bg-accent/10 text-accent">
    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <Fragment set:html={iconSvgs[icon] || iconSvgs['iso']} />
    </svg>
  </div>
  <h3 class="mt-4 text-lg font-bold text-gray-900">{name}</h3>
  <p class="mt-1 text-sm text-gray-600">{description}</p>
</div>
