---
import { productCategories, formConfig } from '../data/siteData';

const selectedProduct = Astro.url.searchParams.get('product') || '';
const isSuccess = Astro.url.searchParams.get('success') === 'true';
---

{isSuccess ? (
  <div class="rounded-lg bg-accent/10 border border-accent/30 p-8 text-center">
    <svg class="mx-auto mb-4 h-16 w-16 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <h3 class="text-2xl font-bold text-gray-900">Thank You!</h3>
    <p class="mt-2 text-gray-600">We have received your enquiry and will respond within 24 hours.</p>
    <a href="/contact" class="mt-6 inline-block rounded-md bg-primary px-6 py-2 text-white font-semibold hover:bg-primary-700 transition-colors">
      Send Another Enquiry
    </a>
  </div>
) : (
  <form
    action="https://api.web3forms.com/submit"
    method="POST"
    class="space-y-5"
  >
    <input type="hidden" name="access_key" value={formConfig.web3formsAccessKey} />
    <input type="hidden" name="redirect" value={`${Astro.site || ''}contact?success=true`} />

    <!-- Honeypot field — hidden from humans, traps bots -->
    <div class="hidden" aria-hidden="true">
      <input type="text" name="botcheck" />
    </div>

    <div>
      <label for="name" class="block text-sm font-medium text-gray-700">Full Name *</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="mt-1 block w-full rounded-md border border-gray-300 px-4 py-2.5 shadow-sm focus:border-primary focus:ring-primary"
        placeholder="Your full name"
      />
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700">Email *</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="mt-1 block w-full rounded-md border border-gray-300 px-4 py-2.5 shadow-sm focus:border-primary focus:ring-primary"
          placeholder="you@company.com"
        />
      </div>
      <div>
        <label for="phone" class="block text-sm font-medium text-gray-700">Phone *</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          required
          class="mt-1 block w-full rounded-md border border-gray-300 px-4 py-2.5 shadow-sm focus:border-primary focus:ring-primary"
          placeholder="+91-XXXXX-XXXXX"
        />
      </div>
    </div>

    <div>
      <label for="company" class="block text-sm font-medium text-gray-700">Company Name</label>
      <input
        type="text"
        id="company"
        name="company"
        class="mt-1 block w-full rounded-md border border-gray-300 px-4 py-2.5 shadow-sm focus:border-primary focus:ring-primary"
        placeholder="Your company name"
      />
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label for="product" class="block text-sm font-medium text-gray-700">Product Interest</label>
        <select
          id="product"
          name="product"
          class="mt-1 block w-full rounded-md border border-gray-300 px-4 py-2.5 shadow-sm focus:border-primary focus:ring-primary"
        >
          <option value="">Select a product...</option>
          {productCategories.map((category) =>
            category.products.map((product) => (
              <option value={product.id} selected={product.id === selectedProduct}>
                {product.name} — {category.title}
              </option>
            ))
          )}
        </select>
      </div>
      <div>
        <label for="quantity" class="block text-sm font-medium text-gray-700">Quantity Required</label>
        <input
          type="text"
          id="quantity"
          name="quantity"
          class="mt-1 block w-full rounded-md border border-gray-300 px-4 py-2.5 shadow-sm focus:border-primary focus:ring-primary"
          placeholder="e.g. 5,000 units"
        />
      </div>
    </div>

    <div>
      <label for="message" class="block text-sm font-medium text-gray-700">Message</label>
      <textarea
        id="message"
        name="message"
        rows="4"
        class="mt-1 block w-full rounded-md border border-gray-300 px-4 py-2.5 shadow-sm focus:border-primary focus:ring-primary"
        placeholder="Tell us about your requirements..."
      ></textarea>
    </div>

    <button
      type="submit"
      class="w-full rounded-md bg-primary px-6 py-3 text-base font-semibold text-white shadow-lg transition-colors hover:bg-primary-700"
    >
      Send Enquiry
    </button>
  </form>
)}
