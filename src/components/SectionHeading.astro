---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  light?: boolean;
}

const { title, subtitle, centered = true, light = false } = Astro.props;
---

<div class:list={['mb-10', centered && 'text-center']}>
  <h2 class:list={['text-3xl font-bold tracking-tight sm:text-4xl', light ? 'text-white' : 'text-gray-900']}>
    {title}
  </h2>
  {subtitle && (
    <p class:list={['mt-3 text-lg', light ? 'text-gray-300' : 'text-gray-600', centered && 'mx-auto max-w-2xl']}>
      {subtitle}
    </p>
  )}
</div>
