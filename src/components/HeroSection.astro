---
interface Props {
  title: string;
  subtitle: string;
  backgroundImage: string;
  ctaText?: string;
  ctaLink?: string;
}

const { title, subtitle, backgroundImage, ctaText, ctaLink } = Astro.props;
---

<section
  class="relative flex min-h-[400px] items-center justify-center bg-cover bg-center px-4 py-20 text-center text-white sm:min-h-[500px]"
  style={`background-image: url('${backgroundImage}')`}
>
  <div class="absolute inset-0 bg-black/50"></div>
  <div class="relative z-10 mx-auto max-w-3xl">
    <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">{title}</h1>
    <p class="mt-4 text-lg text-gray-200 sm:text-xl">{subtitle}</p>
    {ctaText && ctaLink && (
      <a
        href={ctaLink}
        class="mt-8 inline-block rounded-md bg-secondary px-8 py-3 text-base font-semibold text-gray-900 shadow-lg transition-colors hover:bg-secondary-300"
      >
        {ctaText}
      </a>
    )}
  </div>
</section>
