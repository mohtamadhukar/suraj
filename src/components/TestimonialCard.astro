---
interface Props {
  quote: string;
  author: string;
  designation: string;
  company: string;
}

const { quote, author, designation, company } = Astro.props;
---

<div class="rounded-lg bg-white p-8 shadow-md">
  <svg class="mb-4 h-8 w-8 text-secondary" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983z" />
  </svg>
  <blockquote class="text-gray-700 leading-relaxed">{quote}</blockquote>
  <div class="mt-6 border-t border-gray-100 pt-4">
    <p class="font-semibold text-gray-900">{author}</p>
    <p class="text-sm text-gray-500">{designation}, {company}</p>
  </div>
</div>
